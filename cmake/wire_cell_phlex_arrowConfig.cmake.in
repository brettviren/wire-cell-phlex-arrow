@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Arrow is the narrow waist; the rest are the domain + glue dependencies.
find_dependency(Arrow CONFIG)
find_dependency(TBB)
find_dependency(Boost COMPONENTS json)
find_dependency(spdlog)
find_dependency(phlex)
# WireCell ships no config package; the bundled FindWireCell.cmake lives beside
# this file, so add this directory to the module path before finding it.
list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")
find_dependency(WireCell)
find_dependency(wire_cell_arrow CONFIG)
find_dependency(wire_cell_phlex CONFIG)
find_dependency(phlex_arrow_common CONFIG)

include("${CMAKE_CURRENT_LIST_DIR}/wire_cell_phlex_arrowTargets.cmake")

check_required_components(wire_cell_phlex_arrow)
